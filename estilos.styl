color-primario = #ff0000
color-secundario = #ffffff

body
    background-color rgb(209, 206, 206)
    margin-inline 80px

/* Barra de navegación */
.info-busqueda
    display flex
    background-color: color-primario
    width 100%
    height 50px
    align-items center
    p
        color color-secundario
        margin-left 40px
    
    #bar-busqueda
        color: red

.navbar
    height 100px
    background-color color-secundario
    border-bottom: 2px solid color-primario

    #btn-donar
        border-radius 20px
        border none 
        background-color color-primario
        color color-secundario
        padding 5px
        width 100px
        font-weight bold

/* Contenido */
.cont-img-main
    display: flex;
    justify-content: center;
    width: 100%; 
    height: 500px;

    #main-img
        background-color black
        width 100%


.servicios
    display flex
    flex-direction row
    align-items center
    text-align center

    h2
        margin-buttom 20px

    .cont-servicios
        display flex
        justify-content center
        align-items center
        width 400px
        height 300px
        border 1px solid #ccc
        border-radius 10px
        margin 0 20px
        box-shadow 0px 4px 6px rgba(0, 0, 0, 0.1)
        background-color #f9f9f9

/*Ultimas Noticias*/
.contenedor-np
    display flex
    width 100%
    height 450px
    border 1px solid red
    background-color yellow
    .noticias
        border 1px solid red
        width 70%
        padding 10px
        margin-right: 80px
    
    .preguntas
        display: flex;
        flex-direction: column;
        width 30%
        justify-content: center;
        align-items: center;
        margin-left: 80px
        background-color: red
        ul
            list-style-type none
            padding 0
            border: 2px solid green
            border-radius: 10px
            width: 90%
            height 100%
            margin-bottom 40px
            li
                border-bottom 1px solid green
                padding 15px 0

        #ultima-noticia
            width 50%
            height 100%
            background-color: color-secundario

/*Ultimas campañas*/
.campanas
    display flex
    flex-direction row
    align-items center
    text-align center

    h2
        margin-buttom 20px

    .cont-campanas
        display flex
        justify-content center
        align-items center
        width 590px
        height 500px
        border 1px solid #ccc
        border-radius 10px
        margin 0 10px
        box-shadow 0px 4px 6px rgba(0, 0, 0, 0.1)
        background-color #f9f9f9

/*Youtube*/
.yt-seccion
    display: flex
    flex-wrap: nowrap 
    justify-content space-between
    background-color color-primario
    color: color-secundario
    height 500px
    margin-top: 50px


    #cont-video 
        width 50%
        text-align: center
        border 1px solid black  
        position: relative;
        #video
            height: 38%;
            width: 40%;
            background-color: rgb(255, 255, 255);
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            
    #desc-video 
        width 50%
        padding 1rem

        p
            text-align justify

        #sub-boton
            background-color color-secundario
            color color-primario
            border none
            border-radius: 5px
            width 120px
            height 40px
            font-weight bold

.hist-vida 
    display flex
    background-color rgb(157, 0, 255)  
    justify-content center

    gap 300px  
    .historia
        position relative
        display flex
        align-items center
        background-color #fff
        padding 20px
        border-radius 15px
        box-shadow 0px 4px 10px rgba(0, 0, 0, 0.1)
        max-width 500px
        height 400px
        z-index 1 

        .image
            width 250px
            height 250px
            background-color black
            border-radius 10px
            position absolute
            left -30% 
            top 50%
            transform translateY(-50%)
            box-shadow 0px 4px 10px rgba(0, 0, 0, 0.2)

        .content
            margin-left 100px 
            flex 1

/* Ubicación */
.ubicacion
    display flex
    .mapa
        margin 10px
        background-color: green
        width: 70%
        height 350px

    .direccion
        width: 30%;
        padding: 15px;
        justify-content: center;
        align-items: center;
        margin: 10px auto; 
        box-sizing: border-box;
        height 350px 
        #dir
            background-color color-secundario
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
            border-radius: 10px;
            width: 100%; 
            padding: 10px
            margin-block 20px
            box-sizing: border-box; 
            h3
                color color-primario
                margin-bottom: 10px; 

            p
                margin: 1px 0; 
            