color-primario = #dc090f
color-secundario = #fafafa
color-youtube = #8f3434
color-fuente = #8b8b8b
color-bordes = #e5e5e5

body
    background-color rgb(255, 255, 255)
    padding-inline 80px
    margin 0
    font-family Arial, Helvetica, sans-serif
h2
    color color-primario
    text-align center
    margin-block 40px

/* Barra de navegación */
.info-busqueda
    display flex
    background-color: color-primario
    width 100%
    height 50px
    align-items center
    p
        color color-secundario
        margin-left 40px
    
    #bar-busqueda
        color: red

.navbar
    height 100px
    background-color color-secundario
    border-bottom: 2px solid color-primario

    #btn-donar
        border-radius 20px
        border none 
        background-color color-primario
        color color-secundario
        padding 5px
        width 100px
        font-weight bold

/* Contenido */
.cont-img-main
    display: flex;
    justify-content: center;
    width: 100%; 
    height: 500px;

    #main-img
        background-color black
        width 100%

/* Servicios */
.servicios
    display flex
    flex-direction row
    align-items center
    text-align center

    h2
        margin-buttom 20px

    .cont-servicios
        display flex
        justify-content center
        align-items center
        width 400px
        height 300px
        border-radius 10px
        margin 0 20px
        background-color #f9f9f9

/*Ultimas Noticias*/
.contenedor-np
    display flex
    width 100%
    height 450px
    border 1px solid red
    .noticias
        border 1px solid red
        width 70%
        padding 10px
            #ultima-noticia
                border 1px solid black

    .preguntas
        display: flex;
        flex-direction: column;
        width 30%
        justify-content: center;
        align-items: center;
        ul
            list-style-type none
            padding 0
            border: 2px solid color-bordes
            border-radius: 10px
            width: 90%
            height 100%
            margin-bottom 40px
            text-align center

            li
                border-bottom 1px solid color-bordes
                padding 15px 0
                
                a   
                   text-decoration none
                   font-weight bold
                   color color-fuente
                   &:hover
                        color color-primario

                

        #ultima-noticia
            width 50%
            height 100%
            background-color: color-secundario

/* Ultimas campañas */
.campanas
    display flex
    flex-direction row
    align-items center
    text-align center

    h2
        margin-buttom 20px

    .cont-campanas
        display flex
        justify-content center
        align-items center
        width 590px
        height 500px
        border-radius 10px
        margin 0 10px
        box-shadow 0px 4px 6px rgba(0, 0, 0, 0.1)
        background-color #f9f9f9

/* Youtube */
.yt-seccion
    display: flex
    flex-wrap: nowrap 
    justify-content space-between
    background-color color-youtube
    color: color-secundario
    height 500px
    margin-top: 50px
    margin-inline -80px

    #cont-video 
        width 50%
        text-align: center 
        position: relative;
        #video
            height: 43%;
            width: 45%;
            background-color: #ffffff;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            
    #desc-video 
        width 50%
        padding 1rem
        text-align center
        h3
            margin-block 50px

        p
            text-align justify
            margin-inline 15%
            margin-block: 100px

        #sub-boton
            background-color color-secundario
            color color-primario
            border none
            border-radius 5px
            width 120px
            height 40px
            font-weight bold
            font-size 15px

/*Historias de vida*/
.hist-vida 
    display flex 
    justify-content center
    gap 300px  
    .historia
        position relative
        display flex
        align-items center
        background-color color-secundario
        padding 20px
        border-radius 15px
        box-shadow 0px 4px 10px rgba(0, 0, 0, 0.1)
        max-width 500px
        height 400px
        z-index 1
        margin-left 100px

        .image
            width 250px
            height 250px
            background-color black
            border-radius 10px
            position absolute
            left -30% 
            top 50%
            transform translateY(-50%)
            box-shadow 0px 4px 10px rgba(0, 0, 0, 0.2)

        .content
            margin-left 100px 
            flex 1

/* Ubicación */
.ubicacion
    display flex
    .mapa
        margin 10px
        background-color: green
        width: 70%
        height 350px

    .direccion
        width: 30%;
        padding: 15px;
        justify-content: center;
        align-items: center;
        margin: 10px auto; 
        box-sizing: border-box;
        height 350px 
        #dir
            background-color color-secundario
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
            border-radius: 10px;
            width: 100%; 
            padding: 10px
            margin-block 20px
            box-sizing: border-box; 
            h3
                color color-primario
                margin-bottom: 10px; 

            p
                margin: 1px 0; 