/* Ubicación */
.ubicacion
    display flex
    .mapa
        margin 10px
        background-color: black
        width: 70%
        height 350px
        border-radius radio

    .direccion
        width: 30%;
        padding: 15px;
        justify-content: center;
        align-items: center;
        margin: 10px auto; 
        box-sizing: border-box;
        height 350px 
        #dir
            background-color color-secundario
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
            border-radius: radio
            width: 100%; 
            padding: 10px
            margin-block 20px
            box-sizing: border-box; 
            h3
                color color-primario
                margin-bottom: 10px; 

            p
                margin: 1px 0; 

.footer
    background-color color-footer
    position: relative
    display: flex
    justify-content: space-between
    align-items: center
    height: 90px
    color color-secundario
    margin-inline -80px
    

    .izquierda, .derecha
        width: 50%
        text-align: center

    .izquierda
        padding-left: 10px

    .derecha
        padding-right: 10px

/* PAGE-NOTICIA */
.noticias-container
    display grid
    grid-template-columns repeat(2, 1fr)
    grid-template-rows repeat(2, auto) 
    gap 20px
    max-width 100%
    margin 0 auto

    .noti
        padding 20px
        background-color color-secundario
        border-radius: radio
        text-align left
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);

        p
            width: 100%; /* Ajusta según el contenedor */
            display: -webkit-box;
            -webkit-line-clamp: 3; /* Limita a 2 líneas */
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;

    figure
        background-color: color-primario
        border-radius radio-interno
        height 150px
        margin 0
        
        img
            width: 100%
            height 150px
            display: block
            border-radius radio-interno
        
    h2
        color color-primario
        text-align left
        padding 0
        margin 0
        margin-top 1em
        margin-bottom 0.5em

    span
        font-size 10px

.cursos
    display grid
    grid-template-columns: repeat(3, 1fr);
    gap 20px

    .contenedor-cursos
        display contents

        ul
            background-color white
            padding: 10px
            list-style: none;
            text-align: center;
            margin 0